{
    "manifest_version": 3,
    "name": "S4MM - Direct Download",
    "description": "Adds direct download buttons to some Sims Related download websites, like Patreon.",
    "version": "1.1",
    "permissions": ["activeTab", "downloads", "storage"],
    "content_scripts": [{
        "matches": ["https://www.patreon.com/*", "https://www.thesimsresource.com/*"],
        "js": ["content.js"]
    }],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        }
    }
}